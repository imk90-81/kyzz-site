---
import { getCollection } from 'astro:content';

const dailyEntries = (await getCollection('daily', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
};
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>每日动态 | Kyzz空间站</title>
  <meta name="description" content="AI Coding 领域每日精选，值得关注的动态与洞察">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;700&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', 'Noto Sans SC', system-ui, sans-serif;
      background: #0a0a0f;
      color: #e4e4e7;
      min-height: 100vh;
    }

    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      border-bottom: 1px solid rgba(30,30,46,0.5);
      background: rgba(10,10,15,0.8);
      backdrop-filter: blur(12px);
    }
    .nav-inner {
      max-width: 64rem; margin: 0 auto; padding: 0 1.5rem;
      display: flex; align-items: center; justify-content: space-between; height: 4rem;
    }
    .nav-logo { text-decoration: none; font-size: 1.125rem; font-weight: 700; }
    .nav-logo .cyan { color: #00e5ff; }
    .nav-logo .dim { color: #a1a1aa; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      text-decoration: none; font-size: 0.875rem; font-weight: 500; color: #a1a1aa;
      transition: color 0.2s;
    }
    .nav-links a:hover, .nav-links a.active { color: #00e5ff; }
    .nav-links a.active { position: relative; }
    .nav-links a.active::after {
      content: ''; position: absolute; bottom: -2px; left: 0; right: 0;
      height: 2px; background: #00e5ff; border-radius: 1px;
    }

    .main { max-width: 64rem; margin: 0 auto; padding: 7rem 1.5rem 4rem; }

    .page-label {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.75rem; font-family: 'JetBrains Mono', monospace;
      color: #71717a; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 1rem;
    }
    .page-label .dot {
      width: 6px; height: 6px; background: #00e5ff; border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

    .page-title {
      font-size: 1.875rem; font-weight: 700; color: #fff;
      margin-bottom: 0.75rem; letter-spacing: -0.02em;
    }
    .page-desc { color: #a1a1aa; margin-bottom: 3rem; }

    .card-list { display: flex; flex-direction: column; gap: 1rem; }

    .card {
      display: block; text-decoration: none;
      background: rgba(18,18,26,0.2); border: 1px solid rgba(30,30,46,0.5);
      border-radius: 0.75rem; padding: 1.5rem;
      transition: all 0.3s;
    }
    .card:hover {
      border-color: rgba(0,229,255,0.3); background: rgba(18,18,26,0.4);
      transform: translateY(-2px);
      box-shadow: 0 0 25px rgba(0,229,255,0.05);
    }

    .card-top { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
    .card-date {
      font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; color: #71717a;
    }
    .card-badge {
      font-size: 0.625rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 2px 8px; border-radius: 4px;
      background: rgba(0,229,255,0.1); color: #00e5ff; border: 1px solid rgba(0,229,255,0.2);
    }
    .card-title {
      font-size: 1.125rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem;
    }
    .card-excerpt {
      font-size: 0.875rem; color: #a1a1aa; line-height: 1.7;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .card-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
    .card-tag {
      font-size: 0.6875rem; font-family: 'JetBrains Mono', monospace;
      padding: 2px 8px; border-radius: 9999px;
      background: rgba(0,229,255,0.05); border: 1px solid rgba(0,229,255,0.15);
      color: rgba(0,229,255,0.7);
    }

    .footer {
      margin-top: 4rem; padding: 2rem 0; border-top: 1px solid rgba(30,30,46,0.5);
      text-align: center;
    }
    .footer-text { font-size: 0.75rem; color: #52525b; }
    .footer-text a { color: #00e5ff; text-decoration: none; }
  </style>
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a class="nav-logo" href="/"><span class="cyan">Kyzz</span> <span class="dim">空间站</span></a>
    <ul class="nav-links">
      <li><a href="/">首页</a></li>
      <li><a href="/blog">博客</a></li>
      <li><a href="/daily" class="active">动态</a></li>
      <li><a href="/about">关于</a></li>
    </ul>
  </div>
</nav>

<div class="main">
  <div class="page-label"><span class="dot"></span> DAILY DIGEST</div>
  <h1 class="page-title">每日动态</h1>
  <p class="page-desc">AI Coding 领域每日精选，值得关注的动态与洞察</p>

  <div class="card-list">
    {dailyEntries.map(entry => (
      <a class="card" href={`/daily/${entry.slug}`}>
        <div class="card-top">
          <span class="card-date">{formatDate(entry.data.pubDate)}</span>
          <span class="card-badge">DAILY</span>
        </div>
        <div class="card-title">{entry.data.title}</div>
        <div class="card-excerpt">{entry.data.description}</div>
        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="card-tags">
            {entry.data.tags.slice(0, 5).map(tag => (
              <span class="card-tag">#{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>
</div>

<div class="footer">
  <div class="footer-text">&copy; 2026 Kyzz. <a href="/">返回空间站</a></div>
</div>

</body>
</html>
