---
import BaseLayout from '../layouts/BaseLayout.astro';

const techStack = [
  { name: 'TypeScript', category: '语言', icon: '⚡' },
  { name: 'Python', category: '语言', icon: '🐍' },
  { name: 'Rust', category: '语言', icon: '🦀' },
  { name: 'React', category: '前端', icon: '⚛️' },
  { name: 'Vue', category: '前端', icon: '💚' },
  { name: 'Astro', category: '框架', icon: '🚀' },
  { name: 'Node.js', category: '运行时', icon: '🟢' },
  { name: 'Tailwind CSS', category: '样式', icon: '🎨' },
  { name: 'PostgreSQL', category: '数据库', icon: '🐘' },
  { name: 'Docker', category: '运维', icon: '🐳' },
  { name: 'Cloudflare', category: '平台', icon: '☁️' },
  { name: 'Git', category: '工具', icon: '📦' },
];

const socialLinks = [
  { name: 'GitHub', href: 'https://github.com/imk90-81', desc: '@imk90-81' },
  { name: 'Email', href: 'mailto:imkyzz@163.com', desc: 'imkyzz@163.com' },
];
---

<BaseLayout title="关于" description="关于 Kyzz空间站和作者的信息">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-10 sm:py-16">
    {/* Page Header */}
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-cyber-500/60"></div>
        <span class="text-xs font-mono text-zinc-500 tracking-wider uppercase">ABOUT</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
        关于空间站
      </h1>
    </div>

    {/* Intro Section */}
    <section class="mb-16">
      <div class="relative rounded-xl border border-space-500/50 bg-space-700/20 p-6 sm:p-8">
        {/* Glow effect */}
        <div class="absolute top-0 right-0 w-64 h-64 bg-cyber-500/5 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/2"></div>

        <div class="relative z-10">
          <div class="flex items-start gap-4 mb-6">
            {/* Avatar placeholder */}
            <div class="flex-shrink-0 w-16 h-16 rounded-xl bg-gradient-to-br from-cyber-500/20 to-indigo-500/20 border border-cyber-500/20 flex items-center justify-center">
              <span class="text-2xl">🛸</span>
            </div>
            <div>
              <h2 class="text-xl font-bold text-white">Kyzz</h2>
              <p class="text-sm text-zinc-500 font-mono">太空旅客 · 代码探索者</p>
            </div>
          </div>

          <div class="text-zinc-300 leading-relaxed space-y-4">
            <p>
              你好，欢迎来到 Kyzz 空间站。
            </p>
            <p>
              我是一名热爱技术的开发者，对编程语言、系统设计和开源社区有着浓厚的兴趣。
              我相信好的代码应该像好的文章一样——简洁、清晰、有表达力。
            </p>
            <p>
              这个空间站是我的数字花园，记录着我在技术宇宙中的探索轨迹。
              从框架到语言，从架构到运维，从思考到实践，一切值得记录的内容都会在这里留下印记。
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Tech Stack Section */}
    <section class="mb-16">
      <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
        <div class="h-px w-6 bg-cyber-500/60"></div>
        技术栈
      </h2>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {techStack.map((tech) => (
          <div class="group relative rounded-lg border border-space-500/50 bg-space-700/20 px-4 py-3 hover:border-cyber-500/30 transition-all duration-200">
            <div class="flex items-center gap-2">
              <span class="text-base">{tech.icon}</span>
              <div>
                <div class="text-sm font-medium text-zinc-200 group-hover:text-cyber-400 transition-colors">
                  {tech.name}
                </div>
                <div class="text-xs text-zinc-600 font-mono">{tech.category}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* Social Links Section */}
    <section class="mb-16">
      <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
        <div class="h-px w-6 bg-cyber-500/60"></div>
        联系方式
      </h2>

      <div class="space-y-3">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('mailto') ? undefined : '_blank'}
            rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            class="flex items-center justify-between rounded-lg border border-space-500/50 bg-space-700/20 px-5 py-4 hover:border-cyber-500/30 transition-all duration-200 group"
          >
            <div>
              <div class="text-sm font-medium text-zinc-200 group-hover:text-cyber-400 transition-colors">
                {link.name}
              </div>
              <div class="text-sm text-zinc-500 font-mono">{link.desc}</div>
            </div>
            <svg class="w-4 h-4 text-zinc-600 group-hover:text-cyber-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </a>
        ))}
      </div>
    </section>

    {/* Station Info */}
    <section>
      <div class="rounded-xl border border-space-500/50 bg-space-700/20 p-6 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-space-500/50 bg-space-700/30 mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-cyber-500 animate-pulse"></span>
          <span class="text-xs font-mono text-zinc-500">STATION STATUS</span>
        </div>
        <h3 class="text-lg font-bold text-white mb-2">空间站运行中</h3>
        <p class="text-sm text-zinc-500 mb-4">
          构建工具：Astro · 样式：Tailwind CSS · 托管：Cloudflare Pages
        </p>
        <div class="flex justify-center">
          <div class="h-px w-16 bg-gradient-to-r from-transparent via-cyber-500/50 to-transparent"></div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
