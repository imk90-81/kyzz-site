---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft).catch(() => [])).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recentPosts = allPosts.slice(0, 5);

const dailyEntries = (await getCollection('daily', ({ data }) => !data.draft).catch(() => []))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
};

// Skill tags for display
const skills = [
  'TypeScript', 'React', 'Vue', 'Node.js', 'Python',
  'Astro', 'Tailwind', 'Docker', 'Git', 'Rust',
];
---

<BaseLayout title="Kyzz空间站">
  {/* Hero Section */}
  <HeroSection />

  {/* Daily Digest Section */}
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-10">
        <div class="flex items-center gap-3">
          <div class="h-px w-8 bg-cyber-500/60"></div>
          <h2 class="text-xl font-bold text-white tracking-tight">每日动态</h2>
        </div>
        <a
          href="/daily"
          class="group inline-flex items-center gap-1.5 text-sm text-zinc-400 hover:text-cyber-400 transition-colors"
        >
          查看全部
          <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {dailyEntries.map(entry => (
          <a href={`/daily/${entry.slug}`} class="block rounded-xl overflow-hidden border border-space-500/50 bg-space-700/20 hover:border-cyber-500/30 hover:bg-space-700/40 transition-all duration-300 group">
            <div class="p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-mono tracking-wider bg-cyber-500/10 border border-cyber-500/20 text-cyber-400">
                  <span class="w-1 h-1 rounded-full bg-cyber-500 animate-pulse"></span>
                  DAILY
                </span>
                <span class="text-xs text-zinc-500 font-mono">{formatDate(entry.data.pubDate)}</span>
              </div>
              <h3 class="text-base font-bold text-white group-hover:text-cyber-400 transition-colors mb-2">
                {entry.data.title}
              </h3>
              <p class="text-xs text-zinc-500 line-clamp-2">
                {entry.data.description}
              </p>
              {entry.data.tags && entry.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {entry.data.tags.slice(0, 3).map(tag => (
                    <span class="text-xs font-mono text-cyber-400/70 bg-cyber-500/5 border border-cyber-500/10 px-2 py-0.5 rounded">
                      #{tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Recent Posts Section */}
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      {/* Section Header */}
      <div class="flex items-center justify-between mb-10">
        <div class="flex items-center gap-3">
          <div class="h-px w-8 bg-cyber-500/60"></div>
          <h2 class="text-xl font-bold text-white tracking-tight">最新文章</h2>
        </div>
        <a
          href="/blog"
          class="group inline-flex items-center gap-1.5 text-sm text-zinc-400 hover:text-cyber-400 transition-colors"
        >
          查看全部
          <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </a>
      </div>

      {/* Post Grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.slug}
            heroImage={post.data.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  {/* Skills / Tags Section */}
  <section class="py-16 sm:py-24 border-t border-space-500/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-10">
        <div class="h-px w-8 bg-cyber-500/60"></div>
        <h2 class="text-xl font-bold text-white tracking-tight">技术标签</h2>
      </div>

      <div class="flex flex-wrap gap-3">
        {skills.map((skill) => (
          <span class="inline-flex items-center px-4 py-2 rounded-lg text-sm font-mono text-zinc-300 bg-space-700/30 border border-space-500/50 hover:border-cyber-500/30 hover:text-cyber-400 hover:bg-cyber-500/5 transition-all duration-200 cursor-default">
            <span class="mr-2 text-cyber-500/50">λ</span>
            {skill}
          </span>
        ))}
      </div>
    </div>
  </section>

  {/* CTA Section */}
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="relative rounded-2xl overflow-hidden border border-space-500/50 bg-space-700/20 p-8 sm:p-12 text-center">
        {/* Background decoration */}
        <div class="absolute inset-0 grid-bg opacity-20"></div>
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-48 bg-cyber-500/5 rounded-full blur-[80px]"></div>

        <div class="relative z-10">
          <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">探索更多</h2>
          <p class="text-zinc-400 mb-8 max-w-md mx-auto">
            在这个空间站中，有更多关于技术、编程和思考的内容等待你的发现。
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
              href="/blog"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-cyber-500/15 border border-cyber-500/30 text-cyber-400 font-medium hover:bg-cyber-500/25 hover:border-cyber-500/50 transition-all duration-300 hover:shadow-[0_0_20px_rgba(0,229,255,0.1)]"
            >
              浏览博客
            </a>
            <a
              href="/about"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-zinc-400 hover:text-zinc-200 transition-colors"
            >
              关于我
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
