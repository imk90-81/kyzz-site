---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面未找到" description="你访问的页面不存在">
  <div class="flex items-center justify-center min-h-[70vh]">
    <div class="text-center px-4">
      {/* Decorative 404 */}
      <div class="relative mb-8">
        <span class="text-8xl sm:text-9xl font-bold gradient-text opacity-40">404</span>
        {/* Scan lines */}
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-48 h-0.5 bg-gradient-to-r from-transparent via-cyber-500/30 to-transparent"></div>
        </div>
      </div>

      <h1 class="text-2xl font-bold text-white mb-3">页面未找到</h1>
      <p class="text-zinc-400 mb-8 max-w-sm mx-auto">
        你访问的页面可能在另一个维度，或者已经被时空裂缝吞噬了。
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg bg-cyber-500/10 border border-cyber-500/30 text-cyber-400 text-sm font-medium hover:bg-cyber-500/20 hover:border-cyber-500/50 transition-all duration-300"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          返回空间站
        </a>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg text-zinc-400 text-sm font-medium hover:text-zinc-200 transition-colors"
        >
          浏览文章
        </a>
      </div>

      {/* Decorative elements */}
      <div class="mt-12 flex justify-center">
        <div class="dot-bg w-32 h-32 rounded-full opacity-30"></div>
      </div>
    </div>
  </div>
</BaseLayout>
