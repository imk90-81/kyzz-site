---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import TagList from '../../components/TagList.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft).catch(() => [])).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Get all unique tags
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort();

// Get active tag from URL params
const activeTag = Astro.url.searchParams.get('tag') || undefined;

// Filter posts by active tag
const filteredPosts = activeTag
  ? allPosts.filter((post) => post.data.tags.includes(activeTag))
  : allPosts;

const postCount = filteredPosts.length;
---

<BaseLayout title="博客" description="Kyzz空间站的博客文章列表">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-10 sm:py-16">
    {/* Page Header */}
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-cyber-500/60"></div>
        <span class="text-xs font-mono text-zinc-500 tracking-wider uppercase">BLOG</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight mb-3">
        文章列表
      </h1>
      <p class="text-zinc-400">
        共 {postCount} 篇文章{activeTag ? ` · 标签筛选：${activeTag}` : ''}
      </p>
    </div>

    {/* Tag Filter */}
    <div class="mb-10">
      <TagList tags={allTags} activeTag={activeTag} />
      {activeTag && (
        <a
          href="/blog"
          class="inline-flex items-center gap-1 mt-3 text-xs text-zinc-500 hover:text-cyber-400 transition-colors"
        >
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
          清除筛选
        </a>
      )}
    </div>

    {/* Posts Grid */}
    {filteredPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {filteredPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.slug}
            heroImage={post.data.heroImage}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-zinc-500 text-lg mb-4">暂无文章</p>
        <a href="/blog" class="text-cyber-400 hover:text-cyber-300 text-sm">
          查看全部文章 →
        </a>
      </div>
    )}
  </div>
</BaseLayout>
