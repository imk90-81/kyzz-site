---
import ThemeSwitcher from './ThemeSwitcher.astro';
import Search from './Search.astro';

const navLinks = [
  { href: '/', text: '首页' },
  { href: '/blog', text: '博客' },
  { href: '/daily', text: '动态' },
  { href: '/reports', text: '报告' },
  { href: '/about', text: '关于' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b" id="site-header" style="background: var(--color-header-bg, rgba(10,10,15,0.8)); border-color: var(--color-border); backdrop-filter: blur(12px);">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <nav class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="group flex items-center gap-2 text-lg font-bold tracking-tight transition-colors">
        <span class="logo-brand group-hover:logo-brand-hover transition-colors" style="color: var(--color-accent) !important">Kyzz</span>
        <span class="logo-brand-secondary" style="color: var(--color-text-secondary) !important">空间站</span>
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden sm:flex items-center gap-8">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'relative text-sm font-medium transition-colors duration-200',
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'text-cyber-500'
                  : 'text-zinc-400 hover:text-zinc-200',
              ]}
            >
              {link.text}
              {(currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))) && (
                <span class="absolute -bottom-1 left-0 right-0 h-0.5 bg-cyber-500 rounded-full" />
              )}
            </a>
          </li>
        ))}
      </ul>

      <!-- Theme Switcher -->
      <div class="flex items-center gap-1">
        <Search />
        <ThemeSwitcher />
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="sm:hidden p-2 text-zinc-400 hover:text-zinc-200 transition-colors"
        aria-label="打开导航菜单"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          <path id="menu-icon-close" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" class="hidden" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="sm:hidden hidden border-t" style="background: var(--color-header-bg, rgba(10,10,15,0.95)); border-color: var(--color-border); backdrop-filter: blur(12px);">
    <ul class="px-4 py-3 space-y-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block px-3 py-2 rounded-md text-sm font-medium transition-colors',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-cyber-500 bg-cyber-500/10'
                : 'text-zinc-400 hover:text-zinc-200 hover:bg-space-700',
            ]}
          >
            {link.text}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<!-- Add spacer for fixed header -->
<div class="h-16"></div>

<script is:inline>
  function initMobileMenu() {
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    var iconOpen = document.getElementById('menu-icon-open');
    var iconClose = document.getElementById('menu-icon-close');
    if (!btn || !menu) return;

    // Remove old listeners by replacing elements
    var newBtn = btn.cloneNode(true);
    btn.parentNode.replaceChild(newBtn, btn);
    btn = document.getElementById('mobile-menu-btn');

    btn.addEventListener('click', function () {
      var isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      if (iconOpen) iconOpen.classList.toggle('hidden');
      if (iconClose) iconClose.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }

  function initScrollHeader() {
    var header = document.getElementById('site-header');
    if (!header) return;
    window.addEventListener('scroll', function () {
      var scrolled = window.scrollY > 20;
      header.style.borderBottomColor = scrolled ? 'var(--color-border)' : 'transparent';
    }, { passive: true });
  }

  initMobileMenu();
  initScrollHeader();

  document.addEventListener('astro:page-load', function () {
    initMobileMenu();
    initScrollHeader();
  });
</script>
