---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { href: 'https://github.com/kyzz', label: 'GitHub', icon: 'github' },
  { href: 'https://twitter.com/kyzz', label: 'Twitter', icon: 'twitter' },
  { href: 'mailto:hello@kyzz.space', label: 'Email', icon: 'email' },
];
---

<footer class="border-t border-space-500/50 mt-20">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Left: Brand & Copyright -->
      <div class="text-center sm:text-left">
        <a href="/" class="inline-flex items-center gap-2 text-sm font-bold tracking-tight mb-2">
          <span class="text-cyber-500">Kyzz</span>
          <span class="text-zinc-400">空间站</span>
        </a>
        <p class="text-xs text-zinc-500">
          &copy; {currentYear} Kyzz. 在宇宙中漂流的技术笔记。
        </p>
      </div>

      <!-- Right: Social Links -->
      <div class="flex items-center gap-4">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-zinc-500 hover:text-cyber-500 transition-colors duration-200"
            aria-label={link.label}
          >
            {link.icon === 'github' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            )}
            {link.icon === 'twitter' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            )}
            {link.icon === 'email' && (
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>

    <!-- Decorative bottom line -->
    <div class="mt-8 flex justify-center">
      <div class="h-px w-24 bg-gradient-to-r from-transparent via-cyber-500/50 to-transparent"></div>
    </div>
  </div>
</footer>
