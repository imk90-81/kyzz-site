---
const themes = [
  { key: 'cosmos', label: '宇宙', icon: '🌌' },
  { key: 'day',    label: '白昼', icon: '☀️' },
  { key: 'nebula', label: '星云', icon: '🌠' },
];
---

<div class="relative" id="theme-switcher">
  <button
    id="theme-btn"
    class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-sm transition-all duration-200 hover:bg-space-600/50 text-zinc-400 hover:text-zinc-200 border border-transparent hover:border-space-500/50"
    aria-label="切换主题"
    aria-expanded="false"
  >
    <span id="theme-icon" class="text-base">🌌</span>
    <span id="theme-label" class="hidden sm:inline">宇宙</span>
    <svg class="w-3.5 h-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <!-- Dropdown -->
  <div id="theme-dropdown" class="hidden absolute right-0 top-full mt-2 py-1.5 rounded-xl border border-space-500/50 bg-space-800/95 backdrop-blur-md shadow-xl min-w-[120px]">
    {themes.map((t) => (
      <button
        class="theme-option w-full flex items-center gap-2.5 px-3 py-2 text-sm text-zinc-400 hover:text-zinc-200 hover:bg-space-600/50 transition-colors"
        data-theme-key={t.key}
      >
        <span class="text-base">{t.icon}</span>
        <span>{t.label}</span>
        <span class="theme-check ml-auto text-cyber-500 hidden">✓</span>
      </button>
    ))}
  </div>
</div>

<script is:inline>
  (function () {
    function init() {
      var btn       = document.getElementById('theme-btn');
      var dropdown  = document.getElementById('theme-dropdown');
      var icon      = document.getElementById('theme-icon');
      var label     = document.getElementById('theme-label');
      if (!btn || !dropdown) return;

      // Remove old delegated listener (if any) by cloning
      var newBtn      = btn.cloneNode(true);
      var newDropdown = dropdown.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
      dropdown.parentNode.replaceChild(newDropdown, dropdown);
      // Re-query after replace
      btn      = document.getElementById('theme-btn');
      dropdown = document.getElementById('theme-dropdown');
      icon     = document.getElementById('theme-icon');
      label    = document.getElementById('theme-label');

      var options = dropdown.querySelectorAll('.theme-option');
      var themeMap = {
        cosmos:  { icon: '🌌', label: '宇宙' },
        day:     { icon: '☀️', label: '白昼' },
        nebula:  { icon: '🌠', label: '星云' },
      };

      function applyTheme(key) {
        if (key === 'cosmos') {
          document.documentElement.removeAttribute('data-theme');
        } else {
          document.documentElement.setAttribute('data-theme', key);
        }
        try { localStorage.setItem('theme', key); } catch (e) {}
        var t = themeMap[key] || themeMap['cosmos'];
        if (icon)  icon.textContent  = t.icon;
        if (label) label.textContent = t.label;
        for (var i = 0; i < options.length; i++) {
          var check = options[i].querySelector('.theme-check');
          if (!check) continue;
          check.classList.toggle(
            'hidden',
            options[i].getAttribute('data-theme-key') !== key
          );
        }
      }

      // Sync UI to saved theme
      var saved = 'cosmos';
      try { saved = localStorage.getItem('theme') || 'cosmos'; } catch (e) {}
      applyTheme(saved);

      // Bind events (on freshly-cloned nodes — no duplicates)
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        var isOpen = !dropdown.classList.contains('hidden');
        dropdown.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!isOpen));
      });

      for (var i = 0; i < options.length; i++) {
        (function (opt) {
          opt.addEventListener('click', function () {
            var key = opt.getAttribute('data-theme-key') || 'cosmos';
            applyTheme(key);
            dropdown.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
          });
        })(options[i]);
      }

      document.addEventListener('click', function (e) {
        if (!dropdown.classList.contains('hidden') && !dropdown.contains(e.target) && !btn.contains(e.target)) {
          dropdown.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // Run now
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    // Re-run on every Astro page transition
    document.addEventListener('astro:page-load', init);
  })();
</script>
