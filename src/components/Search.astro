---
---
<!-- Search Trigger Button -->
<button
  id="search-trigger"
  class="p-2 text-zinc-400 hover:text-zinc-200 transition-colors"
  aria-label="搜索"
  title="搜索 (Ctrl+K)"
>
  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
  </svg>
</button>

<!-- Search Modal -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>

  <!-- Modal -->
  <div class="relative flex flex-col items-center pt-[15vh] px-4">
    <div id="search-box" class="w-full max-w-2xl rounded-xl overflow-hidden shadow-2xl" style="background: var(--color-bg-secondary); border: 1px solid var(--color-border);">
      <!-- Search Input -->
      <div class="flex items-center px-4 py-3 border-b" style="border-color: var(--color-border);">
        <svg class="h-5 w-5 text-zinc-500 mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="search-input"
          class="flex-1 bg-transparent text-sm outline-none"
          placeholder="搜索文章、动态、报告..."
          style="color: var(--color-text);"
          autocomplete="off"
          spellcheck="false"
        />
        <kbd class="hidden sm:inline-block px-2 py-1 text-xs rounded" style="background: var(--color-bg-tertiary); color: var(--color-text-secondary); border: 1px solid var(--color-border);">ESC</kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto">
        <div id="search-hint" class="px-4 py-8 text-center text-sm" style="color: var(--color-text-secondary);">
          开始输入以搜索...
        </div>
      </div>

      <!-- Footer -->
      <div class="px-4 py-2 flex items-center justify-between border-t text-xs" style="border-color: var(--color-border); color: var(--color-text-secondary);">
        <span>Powered by <span style="color: var(--color-accent);">Pagefind</span></span>
        <div class="flex items-center gap-4">
          <span><kbd class="px-1 py-0.5 rounded" style="background: var(--color-bg-tertiary); border: 1px solid var(--color-border);">↑↓</kbd> 导航</span>
          <span><kbd class="px-1 py-0.5 rounded" style="background: var(--color-bg-tertiary); border: 1px solid var(--color-border);">Enter</kbd> 打开</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  var modal = document.getElementById('search-modal');
  var trigger = document.getElementById('search-trigger');
  var input = document.getElementById('search-input');
  var results = document.getElementById('search-results');
  var hint = document.getElementById('search-hint');
  var backdrop = document.getElementById('search-backdrop');

  if (!modal || !trigger || !input) return;

  var pagefind = null;
  var isLoading = false;

  async function loadPagefind() {
    if (pagefind || isLoading) return pagefind;
    isLoading = true;
    try {
      var pf = await import('/pagefind/pagefind.js');
      await pf.init();
      pagefind = pf;
    } catch (e) {
      console.error('[Search] Pagefind load error:', e);
      pagefind = null;
    }
    isLoading = false;
    return pagefind;
  }

  function openModal() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(function () { input.focus(); }, 50);
    loadPagefind();
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    input.value = '';
    results.innerHTML = '<div id="search-hint" class="px-4 py-8 text-center text-sm" style="color: var(--color-text-secondary);">开始输入以搜索...</div>';
  }

  function highlight(text, term) {
    if (!term || !text) return text;
    try {
      var escaped = term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      var regex = new RegExp('(' + escaped + ')', 'gi');
      return text.replace(regex, '<mark style="background: var(--color-accent); color: #000; border-radius: 2px; padding: 0 2px;">$1</mark>');
    } catch (err) {
      return text;
    }
  }

  async function renderResults(data, term) {
    if (!data || !data.results || data.results.length === 0) {
      results.innerHTML = '<div class="px-4 py-8 text-center text-sm" style="color: var(--color-text-secondary);">未找到相关内容</div>';
      return;
    }

    var limit = Math.min(data.results.length, 10);
    var html = '';

    for (var i = 0; i < limit; i++) {
      var r = data.results[i];
      var title = (r.meta && r.meta.title) ? r.meta.title : (r.url || '');
      var url = r.url || '#';

      // 先用 meta 信息渲染占位，异步加载 content 后更新
      html += '<a href="' + url + '" data-pf-result="' + i + '" class="result-item block px-4 py-3 border-b transition-colors hover:bg-white/5" style="border-color: var(--color-border); text-decoration: none;">';
      html += '<div class="pf-title text-sm font-medium mb-1" style="color: var(--color-text);">' + highlight(title, term) + '</div>';
      html += '<div class="pf-excerpt text-xs" style="color: var(--color-text-secondary);">加载中...</div>';
      html += '</a>';
    }

    results.innerHTML = html;

    // 异步加载每条结果的 excerpt
    for (var j = 0; j < limit; j++) {
      try {
        var item = data.results[j];
        var d = await item.data();
        var el = document.querySelector('[data-pf-result="' + j + '"]');
        if (el && d) {
          var excerptEl = el.querySelector('.pf-excerpt');
          if (excerptEl) {
            var raw = (d.content || '').toString().replace(/<[^>]+>/g, '');
            var shortEx = raw.substring(0, 120) + (raw.length > 120 ? '...' : '');
            excerptEl.innerHTML = highlight(shortEx, term);
          }
          // 更新标题（meta 可能不准确）
          var titleEl = el.querySelector('.pf-title');
          if (titleEl && d.meta && d.meta.title) {
            titleEl.innerHTML = highlight(d.meta.title, term);
          }
        }
      } catch (err) {
        console.warn('[Search] Result ' + j + ' load error:', err);
      }
    }
  }

  var searchTimer = null;

  input.addEventListener('input', function () {
    clearTimeout(searchTimer);
    var q = input.value.trim();
    if (!q) {
      results.innerHTML = '<div id="search-hint" class="px-4 py-8 text-center text-sm" style="color: var(--color-text-secondary);">开始输入以搜索...</div>';
      return;
    }
    searchTimer = setTimeout(async function () {
      var pf = await loadPagefind();
      if (!pf) {
        results.innerHTML = '<div class="px-4 py-8 text-center text-sm" style="color: var(--color-text-secondary);">搜索索引加载失败，请刷新页面重试</div>';
        return;
      }
      results.innerHTML = '<div class="px-4 py-8 text-center text-sm" style="color: var(--color-text-secondary);">搜索中...</div>';
      try {
        var data = await pf.search(q);
        await renderResults(data, q);
      } catch (e) {
        console.error('[Search] Error:', e);
        results.innerHTML = '<div class="px-4 py-8 text-center text-sm" style="color: var(--color-text-secondary);">搜索失败，请重试</div>';
      }
    }, 200);
  });

  // Keyboard navigation
  var activeIndex = -1;
  input.addEventListener('keydown', function (e) {
    var items = results.querySelectorAll('.result-item');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = Math.min(activeIndex + 1, items.length - 1);
      updateActive(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = Math.max(activeIndex - 1, 0);
      updateActive(items);
    } else if (e.key === 'Enter' && activeIndex >= 0) {
      e.preventDefault();
      var target = items[activeIndex];
      if (target) window.location.href = target.getAttribute('href');
    }
  });

  function updateActive(items) {
    for (var k = 0; k < items.length; k++) {
      items[k].style.background = (k === activeIndex) ? 'rgba(255,255,255,0.08)' : '';
    }
  }

  trigger.addEventListener('click', openModal);
  backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      if (modal.classList.contains('hidden')) {
        openModal();
      } else {
        closeModal();
      }
    }
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });
})();
</script>
