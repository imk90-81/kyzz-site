---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const { title, description = 'Kyzz空间站 - 在技术宇宙中漂浮的前哨站', ogImage, ogType = 'website' } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteTitle = title === 'Kyzz空间站' ? title : `${title} | Kyzz空间站`;

// Default OG image using inline SVG data URI
const defaultOgImage = `data:image/svg+xml,${encodeURIComponent(`
<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <rect fill="#0a0a0f" width="1200" height="630"/>
  <text x="600" y="280" text-anchor="middle" fill="#00e5ff" font-family="system-ui, sans-serif" font-size="72" font-weight="bold">Kyzz空间站</text>
  <text x="600" y="360" text-anchor="middle" fill="#a1a1aa" font-family="system-ui, sans-serif" font-size="28">在技术宇宙中漂浮的前哨站</text>
</svg>
`)}`;
const finalOgImage = ogImage || defaultOgImage;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{siteTitle}</title>
    <meta name="title" content={siteTitle} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={finalOgImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={finalOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Kyzz空间站 RSS Feed" href="/rss.xml" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#00e5ff" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />

    <!-- View Transitions -->
    <ViewTransitions />
    <slot name="head" />

    <!-- JSON-LD WebSite Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Kyzz空间站",
      "url": Astro.site?.toString() || "https://kyzz.space",
      "description": "在技术宇宙中漂浮的前哨站",
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${Astro.site}search?q={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    })} />
  </head>
  <body class="min-h-screen bg-space-900 text-zinc-200 antialiased pb-10">
    <!-- Skip to content link for accessibility -->
    <a class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-cyber-500 focus:text-space-900 focus:font-bold" href="#main-content">跳转到内容</a>
    
    <Header />
    <main id="main-content" class="min-h-[calc(100vh-4rem)]">
      <slot />
    </main>
    <Footer />

    <!-- AI 生成内容提示栏 -->
    <div class="fixed bottom-0 left-0 right-0 z-40 border-t border-space-500/50 bg-space-900/95 backdrop-blur-sm ai-disclaimer-bar">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-center gap-3 text-xs ai-disclaimer-text">
        <span class="ai-emoji">🤖</span>
        <span>本站所有内容均为 <span class="ai-highlight font-medium">AI 生成</span>，</span>
        <span class="hidden sm:inline">仅供参考，请自主核实信息真实性。</span>
        <span class="sm:hidden">请自主核实真实性。</span>
      </div>
    </div>

    <!-- Scroll to top button -->
    <button
      id="scroll-to-top"
      class="fixed bottom-14 right-6 z-50 p-3 rounded-full bg-cyber-500/10 border border-cyber-500/30 text-cyber-400 opacity-0 pointer-events-none transition-all duration-300 hover:bg-cyber-500/20 hover:border-cyber-500/50 hover:shadow-[0_0_20px_rgba(0,229,255,0.15)]"
      aria-label="回到顶部"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
      </svg>
    </button>

    <script>
      // Scroll to top button logic
      const scrollToTopBtn = document.getElementById('scroll-to-top');
      if (scrollToTopBtn) {
        const toggleVisibility = () => {
          if (window.scrollY > 300) {
            scrollToTopBtn.classList.remove('opacity-0', 'pointer-events-none');
            scrollToTopBtn.classList.add('opacity-100', 'pointer-events-auto');
          } else {
            scrollToTopBtn.classList.add('opacity-0', 'pointer-events-none');
            scrollToTopBtn.classList.remove('opacity-100', 'pointer-events-auto');
          }
        };

        window.addEventListener('scroll', toggleVisibility, { passive: true });
        
        scrollToTopBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        // Initial check
        toggleVisibility();
      }
    </script>
  </body>
</html>
